#!/usr/bin/env sh

# Get staged files
staged_files=$(git diff --cached --name-only)

# Check if any staged files are empty
if [ -z "$staged_files" ]; then
  exit 0
fi

echo "🔍 Checking for package changes..."

# Bump only packages with changes
bumped_packages=""
for package_dir in packages/*; do
  if [ -d "$package_dir" ] && [ -f "$package_dir/package.json" ]; then
    # Check if this package has changes (excluding package.json)
    if echo "$staged_files" | grep "^$package_dir/" | grep -v "package.json$" | grep -q .; then
      package_name=$(node -p "require('./$package_dir/package.json').name")
      (cd "$package_dir" && npm version patch --no-git-tag-version)
      echo "📦 Bumped $package_name"
      git add "$package_dir/package.json"
      bumped_packages="$bumped_packages $package_name"
    fi
  fi
done

if [ -n "$bumped_packages" ]; then
  git add package-lock.json
fi

# Ryziz package - sync dependencies with core packages
if [ -n "$bumped_packages" ]; then
  echo "🔄 Syncing Ryziz template dependencies..."
  template_updated=false

  # Sync only bumped packages
  for package_dir in packages/*; do
    if [ -d "$package_dir" ] && [ -f "$package_dir/package.json" ]; then
      package_name=$(node -p "require('./$package_dir/package.json').name")

      # Check if this package was bumped
      if echo "$bumped_packages" | grep -q "$package_name"; then
        package_version=$(node -p "require('./$package_dir/package.json').version")
        template_version=$(node -p "require('./templates/ryziz/package.json').dependencies['$package_name'] || 'none'")

        if [ "$template_version" != "^$package_version" ] && [ "$template_version" != "none" ]; then
          echo "  📝 Updating $package_name: $template_version -> ^$package_version"
          (cd templates/ryziz && npm pkg set dependencies.$package_name="^$package_version")
          template_updated=true
        fi
      fi
    fi
  done
fi

# Bump template version if dependencies were updated OR if template files changed
template_files_changed=false
if echo "$staged_files" | grep "^templates/ryziz/" | grep -v "package.json$" | grep -q .; then
  template_files_changed=true
fi

if [ "$template_updated" = true ] || [ "$template_files_changed" = true ]; then
  echo "📦 Bumping version for @ryziz-shopify/ryziz..."
  (cd templates/ryziz && npm version patch --no-git-tag-version)
  git add templates/ryziz/package.json package-lock.json

  if [ "$template_updated" = true ]; then
    echo "  ✅ Template dependencies synced"
  fi
fi

# Summary
if [ -z "$bumped_packages" ] && [ "$template_files_changed" = false ] && [ "$template_updated" = false ]; then
  echo "ℹ️  No package changes detected"
else
  echo "✅ Version bump completed"
fi
