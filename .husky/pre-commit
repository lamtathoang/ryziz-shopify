#!/usr/bin/env sh

# Get staged files
staged_files=$(git diff --cached --name-only)

# Check if any staged files are empty
if [ -z "$staged_files" ]; then
  exit 0
fi

echo "🔍 Checking for package changes..."

# Count bumped packages
bumped_count=0

# Bump version for changed packages (patch by default)
# CLI package
if echo "$staged_files" | grep "^packages/cli/" | grep -v "package.json$" | grep -q .; then
  echo "📦 Bumping version for @ryziz-shopify/cli..."
  (cd packages/cli && npm version patch --no-git-tag-version)
  git add packages/cli/package.json
  bumped_count=$((bumped_count + 1))
fi

# Functions package
if echo "$staged_files" | grep "^packages/functions/" | grep -v "package.json$" | grep -q .; then
  echo "📦 Bumping version for @ryziz-shopify/functions..."
  (cd packages/functions && npm version patch --no-git-tag-version)
  git add packages/functions/package.json
  bumped_count=$((bumped_count + 1))
fi

# Router package
if echo "$staged_files" | grep "^packages/router/" | grep -v "package.json$" | grep -q .; then
  echo "📦 Bumping version for @ryziz-shopify/router..."
  (cd packages/router && npm version patch --no-git-tag-version)
  git add packages/router/package.json
  bumped_count=$((bumped_count + 1))
fi

# Ryziz package
if echo "$staged_files" | grep "^packages/ryziz/" | grep -v "package.json$" | grep -q .; then
  echo "📦 Bumping version for @ryziz-shopify/ryziz..."
  (cd packages/ryziz && npm version patch --no-git-tag-version)
  git add packages/ryziz/package.json
  bumped_count=$((bumped_count + 1))
fi

if [ "$bumped_count" -eq 0 ]; then
  echo "ℹ️  No package changes detected"
else
  echo "✅ Bumped $bumped_count package(s)"
fi
